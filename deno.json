{
  "name": "@gaato/yt-poster",
  "version": "0.2.0",
  "license": "BlueOak-1.0.0",
  "exports": "./src/main.ts",
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-env --allow-net --allow-read --allow-write --allow-sys src/main.ts",
    "check": "deno fmt --check && deno lint && deno check src/main.ts",
    "test": "deno test --allow-env --allow-net --allow-read --allow-write --allow-sys"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv": "jsr:@std/dotenv@0.225",
    "discordeno": "npm:discordeno@21.0.0",
    "fresh": "jsr:@fresh/core@^2",
    "twitter-api-v2": "npm:twitter-api-v2@1.29.0"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {}
  }
}
